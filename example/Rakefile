# Self-contained build/run example for picoruby-foundation-model.
# Clones upstream picoruby and builds a single self-contained `fmdemo` binary
# with app.rb embedded (see mrbgems/picoruby-bin-fmdemo).
#
#   rake          # == rake build
#   rake build    # clone picoruby (if needed) + build into example/build
#   rake run      # run the embedded-app binary
#   rake clean    # remove example/build
require "shellwords"

EXAMPLE_DIR = __dir__
FORK_ROOT   = File.join(EXAMPLE_DIR, "picoruby")
BUILD_DIR   = File.join(EXAMPLE_DIR, "build")
HOST_BIN    = File.join(BUILD_DIR, "host", "bin", "fmdemo")
CONFIG      = File.join(EXAMPLE_DIR, "build_config.rb")
PICORUBY_REPO = "https://github.com/picoruby/picoruby"

task :picoruby do
  next if Dir.exist?(File.join(FORK_ROOT, ".git"))
  sh "git", "clone", "--recursive", PICORUBY_REPO, FORK_ROOT
end

desc "Clone picoruby (if needed) and build the single binary into example/build"
task build: :picoruby do
  cmd = "cd #{FORK_ROOT.shellescape} && rake"
  sh({ "MRUBY_CONFIG" => CONFIG, "MRUBY_BUILD_DIR" => BUILD_DIR }, cmd)
  raise "build finished but #{HOST_BIN} is missing" unless File.executable?(HOST_BIN)
  puts "Built: #{HOST_BIN}"
end

desc "Run the single binary (app.rb is embedded)"
task :run do
  raise "Not built. Run `rake build` first." unless File.executable?(HOST_BIN)
  exec(HOST_BIN)
end

desc "Remove example/build"
task :clean do
  rm_rf BUILD_DIR
end

task default: :build
